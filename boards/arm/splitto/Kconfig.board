config BOARD_SPLITTO_LEFT
    bool "splitto_left"
    depends on SOC_NRF52840_QIAA
    select ZMK_BOARD_COMPAT
    imply RETAINED_MEM
    imply RETENTION
    imply RETENTION_BOOT_MODE

config BOARD_SPLITTO_RIGHT
    bool "splitto_right"
    depends on SOC_NRF52840_QIAA
    select ZMK_BOARD_COMPAT
    imply RETAINED_MEM
    imply RETENTION
    imply RETENTION_BOOT_MODE